#!/usr/bin/env python3
"""Introspect CLI and terminal dashboard."""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import shutil
import subprocess
import sys
import time
from collections import Counter
from pathlib import Path


REPO = Path(__file__).resolve().parents[1]
DEFAULT_HOME = Path(os.environ.get("INTROSPECT_HOME", "~/.introspect")).expanduser()
DEFAULT_FEEDBACK = Path(os.environ.get("INTROSPECT_FEEDBACK_DIR", str(DEFAULT_HOME / "feedback"))).expanduser()
SETTINGS = DEFAULT_HOME / "settings.json"
SCAN_STATE = DEFAULT_FEEDBACK / "codex-transcript-scan-state.json"
CODEX_SESSIONS_DIR = Path(os.environ.get("INTROSPECT_CODEX_SESSIONS_DIR", "~/.codex/sessions")).expanduser()
CLAUDE_PROJECTS_DIR = Path(os.environ.get("INTROSPECT_CLAUDE_PROJECTS_DIR", "~/.claude/projects")).expanduser()
INTROSPECT_STATE_DIR = DEFAULT_HOME / "introspect"
RUNS_DIR = DEFAULT_HOME / "runs"


def run(cmd: list[str], *, env: dict[str, str] | None = None) -> int:
    return subprocess.call(cmd, cwd=REPO, env=env or os.environ.copy())


def read_json(path: Path, default):
    try:
        return json.loads(path.read_text())
    except Exception:
        return default


def read_jsonl(path: Path) -> list[dict]:
    rows: list[dict] = []
    try:
        lines = path.read_text(errors="replace").splitlines()
    except OSError:
        return rows
    for line in lines:
        if not line.strip():
            continue
        try:
            row = json.loads(line)
        except Exception:
            continue
        if isinstance(row, dict):
            rows.append(row)
    return rows


def pid_alive(pid: int) -> bool:
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except Exception:
        return False


def normalized_invocation(invocation: dict) -> dict:
    normalized = dict(invocation)
    status = str(normalized.get("status") or "")
    if status not in {"starting", "running"}:
        return normalized

    pid = int(normalized.get("pid") or 0)
    exit_code = normalized.get("exit_code")
    if exit_code is not None:
        normalized["reported_status"] = status
        normalized["status"] = "completed" if int(exit_code) == 0 else "failed"
    elif pid and not pid_alive(pid):
        normalized["reported_status"] = status
        normalized["status"] = "stale"
    return normalized


def short(value: object, fallback: str = "-") -> str:
    text = str(value or "").strip()
    return text or fallback


def one_line(value: object, fallback: str = "-") -> str:
    return " ".join(short(value, fallback).split())


def terminal_width(default: int = 100) -> int:
    return shutil.get_terminal_size((default, 40)).columns


def bar(label: str, value: int, total: int, width: int = 28, suffix: str = "") -> str:
    total = max(total, 1)
    filled = min(width, int(round(width * value / total)))
    pct = value / total * 100
    tail = suffix or f"{value} ({pct:.1f}%)"
    return f"{label:<14} [{'#' * filled}{'.' * (width - filled)}] {tail}"


def parse_ts(value: object) -> dt.datetime | None:
    if not isinstance(value, str) or not value.strip():
        return None
    try:
        parsed = dt.datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    return parsed.astimezone(dt.timezone.utc)


def iso_now() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat(timespec="seconds")


def file_stamp() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def write_json(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + f".{os.getpid()}.tmp")
    tmp.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n")
    os.replace(tmp, path)


def sha256_file(path: Path, *, max_bytes: int = 1024 * 1024) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as f:
        remaining = max_bytes
        while remaining > 0:
            chunk = f.read(min(65536, remaining))
            if not chunk:
                break
            digest.update(chunk)
            remaining -= len(chunk)
    return digest.hexdigest()


def prompt_links() -> list[tuple[str, Path, bool]]:
    prompt = DEFAULT_HOME / "AGENTS.md"
    links = [
        ("claude", Path.home() / ".claude" / "CLAUDE.md"),
        ("codex", Path.home() / ".codex" / "AGENTS.md"),
        ("opencode", Path.home() / ".config" / "opencode" / "AGENTS.md"),
    ]
    result = []
    for label, path in links:
        try:
            ok = path.is_symlink() and path.resolve(strict=False) == prompt.resolve(strict=False)
        except OSError:
            ok = False
        result.append((label, path, ok))
    return result


def latest_file(directory: Path, pattern: str) -> Path | None:
    try:
        candidates = [path for path in directory.glob(pattern) if path.is_file()]
    except OSError:
        return None
    if not candidates:
        return None
    return max(candidates, key=lambda path: path.stat().st_mtime)


def install(args: argparse.Namespace) -> int:
    cmd = [str(REPO / "scripts" / "install-hooks.sh")]
    cmd.extend(args.install_args)
    return run(cmd)


def uninstall(_args: argparse.Namespace) -> int:
    return run([str(REPO / "scripts" / "install-hooks.sh"), "--uninstall"])


def status(_args: argparse.Namespace) -> int:
    return run([str(REPO / "scripts" / "introspect-status.sh")])


def doctor(args: argparse.Namespace) -> int:
    code = status(args)
    if code != 0:
        return code
    print()
    print("doctor:")
    for name in ["claude", "codex", "opencode"]:
        found = shutil.which(name)
        print(f"  {name:<8} {found or 'not found'}")
    print(f"  runtime  {REPO}")
    print(f"  home     {DEFAULT_HOME}")
    print(f"  feedback {DEFAULT_FEEDBACK}")
    return 0


def rule(width: int, char: str = "=") -> str:
    return char * min(width, 72)


def plural(count: object, noun: str) -> str:
    try:
        number = int(count)
    except (TypeError, ValueError):
        number = 0
    return f"{number} {noun}{'' if number == 1 else 's'}"


def is_configured() -> bool:
    """True once Introspect has been installed on this machine."""
    if any(ok for _label, _path, ok in prompt_links()):
        return True
    return SCAN_STATE.exists()


def count_transcripts() -> tuple[int, int]:
    """Count local Codex and Claude conversation files, read-only."""

    def count(directory: Path, pattern: str) -> int:
        try:
            return sum(1 for path in directory.rglob(pattern) if path.is_file())
        except OSError:
            return 0

    return (
        count(CODEX_SESSIONS_DIR, "rollout-*.jsonl"),
        count(CLAUDE_PROJECTS_DIR, "*.jsonl"),
    )


def recent_transcript_files(host: str, *, limit: int = 20) -> list[Path]:
    roots: list[tuple[Path, str]]
    if host == "codex":
        roots = [(CODEX_SESSIONS_DIR, "rollout-*.jsonl")]
    elif host == "claude":
        roots = [(CLAUDE_PROJECTS_DIR, "*.jsonl")]
    else:
        roots = [
            (CODEX_SESSIONS_DIR, "rollout-*.jsonl"),
            (CLAUDE_PROJECTS_DIR, "*.jsonl"),
        ]
    files: list[Path] = []
    for root, pattern in roots:
        try:
            files.extend(path for path in root.rglob(pattern) if path.is_file())
        except OSError:
            continue
    return sorted(files, key=lambda path: path.stat().st_mtime, reverse=True)[:limit]


def transcript_snapshot(path: Path) -> dict:
    stat = path.stat()
    return {
        "path": str(path),
        "mtime_ns": stat.st_mtime_ns,
        "size": stat.st_size,
        "sha256_head": sha256_file(path),
    }


def changed_transcripts(paths: list[Path], index: dict) -> tuple[list[dict], list[dict]]:
    known = index.get("transcripts")
    if not isinstance(known, dict):
        known = {}
    changed: list[dict] = []
    snapshots: list[dict] = []
    for path in paths:
        try:
            snapshot = transcript_snapshot(path)
        except OSError:
            continue
        previous = known.get(str(path))
        snapshots.append(snapshot)
        if not isinstance(previous, dict):
            changed.append(snapshot)
            continue
        for key in ("mtime_ns", "size", "sha256_head"):
            if previous.get(key) != snapshot.get(key):
                changed.append(snapshot)
                break
    return changed, snapshots


def write_introspect_result(result: dict, *, summary: str) -> Path:
    run_id = result["run_id"]
    run_dir = RUNS_DIR / run_id
    run_dir.mkdir(parents=True, exist_ok=True)
    write_json(run_dir / "result.json", result)
    (run_dir / "summary.md").write_text(summary.rstrip() + "\n")
    return run_dir


def introspect_summary(result: dict) -> str:
    changed = result.get("changed_transcripts") or []
    lines = [
        "# Introspect Run",
        "",
        f"- Status: {result.get('status')}",
        f"- Host: {result.get('host')}",
        f"- Event: {result.get('event')}",
        f"- Changed transcripts: {len(changed)}",
        f"- Message: {result.get('message')}",
        "",
        "## Changed Transcript Inputs",
        "",
    ]
    if changed:
        for item in changed:
            lines.append(f"- {item.get('path')}")
    else:
        lines.append("- none")
    lines.extend(
        [
            "",
            "## Scope",
            "",
            "This run updated cadence/index artifacts only. It did not edit AGENTS.md, skills, memory, or classifier models.",
        ]
    )
    return "\n".join(lines)


def run_introspect(args: argparse.Namespace) -> int:
    host = args.host
    state_dir = INTROSPECT_STATE_DIR / host
    state_path = state_dir / "state.json"
    index_path = state_dir / "transcript-index.json"
    state = read_json(state_path, {})
    index = read_json(index_path, {})
    now = iso_now()

    turn_count = int(state.get("completed_turns_since_run") or 0)
    if args.event == "stop":
        turn_count += 1

    transcript_paths = [Path(path).expanduser() for path in args.transcript_path]
    if not transcript_paths:
        transcript_paths = recent_transcript_files(host)
    transcript_paths = [path for path in transcript_paths if path.exists()]
    changed, snapshots = changed_transcripts(transcript_paths, index)

    generation_id = args.generation_id or args.session_id or ""
    last_generation_id = str(state.get("last_generation_id") or "")
    last_run_at = parse_ts(state.get("last_run_at"))
    minutes_since_run = None
    if last_run_at is not None:
        minutes_since_run = (
            dt.datetime.now(dt.timezone.utc) - last_run_at
        ).total_seconds() / 60

    skip_reason = ""
    if not args.force and args.event == "stop":
        if generation_id and generation_id == last_generation_id:
            skip_reason = "generation already processed"
        elif turn_count < args.min_turns:
            skip_reason = f"cadence needs {args.min_turns} completed turns"
        elif minutes_since_run is not None and minutes_since_run < args.min_minutes:
            skip_reason = f"cadence needs {args.min_minutes} minutes since last run"
        elif not changed:
            skip_reason = "no changed transcripts"

    state.update(
        {
            "host": host,
            "last_observed_at": now,
            "completed_turns_since_run": turn_count,
            "last_generation_id": generation_id or last_generation_id,
            "last_cwd": args.cwd,
        }
    )

    if skip_reason:
        state["last_skip_reason"] = skip_reason
        write_json(state_path, state)
        payload = {
            "status": "skipped",
            "host": host,
            "event": args.event,
            "message": skip_reason,
            "changed_transcript_count": len(changed),
        }
        if args.json:
            print(json.dumps(payload, sort_keys=True))
        else:
            print(f"Introspect skipped: {skip_reason}")
        return 0

    known = index.get("transcripts")
    if not isinstance(known, dict):
        known = {}
    for snapshot in snapshots:
        known[str(snapshot["path"])] = snapshot
    index = {
        "host": host,
        "updated_at": now,
        "transcripts": known,
    }
    write_json(index_path, index)

    run_id = f"{file_stamp()}-introspect-{host}"
    result = {
        "run_id": run_id,
        "status": "no_change",
        "host": host,
        "event": args.event,
        "cwd": args.cwd,
        "session_id": args.session_id,
        "generation_id": generation_id,
        "apply": args.apply,
        "message": "No high-signal memory updates.",
        "changed_transcripts": changed,
        "transcript_count": len(snapshots),
        "changed_transcript_count": len(changed),
        "mutated_targets": [],
        "classifier_training": False,
    }
    run_dir = write_introspect_result(
        result,
        summary=introspect_summary(result),
    )

    state.update(
        {
            "last_run_at": now,
            "completed_turns_since_run": 0,
            "last_result": str(run_dir / "result.json"),
            "last_summary": str(run_dir / "summary.md"),
            "last_skip_reason": "",
        }
    )
    write_json(state_path, state)

    if args.json:
        print(json.dumps(result, sort_keys=True))
    else:
        print(result["message"])
        print(f"run: {run_dir}")
    return 0


def print_welcome(width: int) -> None:
    print("Introspect")
    print(rule(width))
    print(
        "Introspect watches your local Claude, Codex, and OpenCode sessions for\n"
        "moments where the agent got stuck, ignored instructions, overclaimed, or\n"
        "needed repeated correction. When it sees one, it runs a background\n"
        "reflection pass and updates the right instruction file: a global or\n"
        "project AGENTS.md, a skill, or local memory."
    )
    print()
    print("Everything stays on this machine under ~/.introspect.")


def onboard(args: argparse.Namespace) -> int:
    width = terminal_width()
    print_welcome(width)
    print()

    codex_n, claude_n = count_transcripts()
    total = codex_n + claude_n
    print("Scanning local agent history")
    print(rule(width, "-"))
    print(f"  Codex sessions        {codex_n}")
    print(f"  Claude conversations  {claude_n}")
    print(f"  {'-' * 20}")
    if total:
        print(f"  {total} past conversations found on this machine")
    else:
        print("  No local Claude/Codex history yet. Introspect will watch new")
        print("  conversations as they happen.")
    print()

    already = is_configured()
    if already and not getattr(args, "force", False):
        print("Introspect is already set up here. Showing your dashboard.")
        print()
        render_dashboard()
        return 0

    interactive = sys.stdin.isatty() and sys.stdout.isatty()
    print("Setup will:")
    print("  - link ~/.claude/CLAUDE.md, ~/.codex/AGENTS.md, and")
    print("    ~/.config/opencode/AGENTS.md to ~/.introspect/AGENTS.md")
    print("    (any existing files are backed up first)")
    print("  - install prompt hooks and an event-driven transcript watcher")
    print("  - analyze your recent conversations to calibrate the wake detector")
    print("    (old history is scored for signal only; it never rewrites your files)")
    print()

    if not getattr(args, "yes", False):
        if not interactive:
            print("Non-interactive shell. To set up, run:")
            print("  introspect install        # scriptable, no prompts")
            print("  introspect onboard --yes  # this guided flow, auto-confirmed")
            return 0
        try:
            answer = input("Proceed? [Y/n] ").strip().lower()
        except EOFError:
            answer = "n"
        if answer in ("n", "no"):
            print()
            print("Skipped. When you're ready: introspect install")
            return 0
    print()

    print("Setting up Introspect")
    print(rule(width, "-"))
    print("  Linking agent prompts, installing hooks and the transcript watcher,")
    print("  then analyzing recent history. This takes a few seconds...")
    print()
    proc = subprocess.run(
        [str(REPO / "scripts" / "install-hooks.sh")],
        cwd=REPO,
        capture_output=True,
        text=True,
    )

    for label, _path, link_ok in prompt_links():
        print(f"  [{'ok' if link_ok else '--'}] {label} prompt linked")
    print(f"  [{'ok' if SCAN_STATE.exists() else '--'}] transcript watcher installed")
    scan_state = read_json(SCAN_STATE, {})
    if scan_state.get("last_backfill_at"):
        print(
            f"  [ok] analyzed {plural(scan_state.get('last_backfill_files'), 'recent conversation')}, "
            f"scored {plural(scan_state.get('last_backfill_new_events'), 'message')}, "
            f"flagged {plural(scan_state.get('last_backfill_triggered_events'), 'correction moment')}"
        )
    else:
        print("  [--] history analysis skipped")

    if proc.returncode != 0:
        print()
        print("  Setup reported a problem. Installer output:")
        for line in (proc.stdout + proc.stderr).strip().splitlines()[-20:]:
            print(f"    {line}")
        return proc.returncode

    print()
    print("Introspect is now watching")
    print(rule(width, "-"))
    print("  It runs one reflection pass when it detects a correction in a live")
    print("  session, then updates the right instruction file. You get a")
    print("  notification when a run starts. Here is your dashboard:")
    print()
    print(rule(width))
    print()
    render_dashboard()
    return 0


def load_events() -> list[dict]:
    return read_jsonl(DEFAULT_FEEDBACK / "events.jsonl")


def load_signal_summary(events: list[dict]) -> dict[str, int]:
    total = len(events)
    woke = sum(1 for event in events if event.get("triggered"))
    review = sum(1 for event in events if event.get("review_triggered") and not event.get("triggered"))
    backfilled = sum(1 for event in events if event.get("backfilled"))
    assistant = sum(1 for event in events if event.get("role") == "assistant")
    return {
        "total": total,
        "woke": woke,
        "review": review,
        "backfilled": backfilled,
        "assistant": assistant,
    }


def render_event_trend(events: list[dict], width: int = 32) -> None:
    print("Trend (last 7 days)")
    today = dt.datetime.now(dt.timezone.utc).date()
    days = [today - dt.timedelta(days=offset) for offset in range(6, -1, -1)]
    by_day: dict[dt.date, Counter] = {day: Counter() for day in days}
    for event in events:
        ts = parse_ts(event.get("observed_at") or event.get("ts"))
        if ts is None or ts.date() not in by_day:
            continue
        by_day[ts.date()]["logged"] += 1
        if event.get("triggered"):
            by_day[ts.date()]["woke"] += 1
        elif event.get("review_triggered"):
            by_day[ts.date()]["review"] += 1
    max_logged = max([by_day[day]["logged"] for day in days] + [1])
    for day in days:
        row = by_day[day]
        logged_width = int(round(width * row["logged"] / max_logged)) if row["logged"] else 0
        woke_width = int(round(width * row["woke"] / max_logged)) if row["woke"] else 0
        review_width = int(round(width * row["review"] / max_logged)) if row["review"] else 0
        if row["woke"] and woke_width == 0:
            woke_width = 1
        if row["review"] and review_width == 0:
            review_width = 1
        if row["logged"] and logged_width < woke_width + review_width:
            logged_width = min(width, woke_width + review_width)
        rest = max(logged_width - woke_width - review_width, 0)
        chart = "#" * woke_width + "+" * review_width + "." * rest
        chart = chart.ljust(width)
        label = day.strftime("%m-%d")
        print(f"  {label} [{chart}] logged={row['logged']} woke={row['woke']} review={row['review']}")
    print("  legend: # woke, + review-only, . logged")


def render_score_distribution(events: list[dict], width: int = 24) -> None:
    buckets = [0, 0, 0, 0, 0]
    for event in events:
        classifier = event.get("classifier")
        if not isinstance(classifier, dict):
            continue
        score = classifier.get("score")
        if not isinstance(score, (int, float)):
            continue
        index = min(4, max(0, int(float(score) * 5)))
        buckets[index] += 1
    total = max(max(buckets), 1)
    labels = ["0.0-0.2", "0.2-0.4", "0.4-0.6", "0.6-0.8", "0.8-1.0"]
    print("Wake Score Distribution")
    for label, count in zip(labels, buckets):
        filled = int(round(width * count / total)) if count else 0
        print(f"  {label} [{'#' * filled}{'.' * (width - filled)}] {count}")


def latest_diff_summary() -> tuple[str, list[str]]:
    path = latest_file(DEFAULT_FEEDBACK / "surface-diffs", "*.json")
    if path is None:
        return "none", []
    payload = read_json(path, {})
    changes = payload.get("changes", [])
    lines = [f"{path.name}: changed={payload.get('changed_count', 0)}"]
    for change in changes[:3] if isinstance(changes, list) else []:
        if not isinstance(change, dict):
            continue
        lines.append(
            f"{short(change.get('change_type')):<8} {short(change.get('kind')):<12} {short(change.get('display_path'))}"
        )
    return str(path), lines


def render_queue(queue: list[dict], width: int) -> None:
    print(f"Queue ({len(queue)})")
    if not queue:
        print("  empty")
        return
    for event in queue[-4:]:
        ts = short(event.get("ts") or event.get("observed_at"))
        source = one_line(event.get("source"))
        if len(source) > 16:
            source = source[:15] + "~"
        score = "-"
        classifier = event.get("classifier")
        if isinstance(classifier, dict) and isinstance(classifier.get("score"), (int, float)):
            score = f"{float(classifier['score']):.2f}"
        snippet = one_line(event.get("snippet") or event.get("prompt"))
        prefix = f"  {ts[:19]} {source:<16} score={score:<4} "
        max_snippet = max(12, width - len(prefix) - 1)
        if len(snippet) > max_snippet:
            snippet = snippet[: max_snippet - 3] + "..."
        print(prefix + snippet)


def render_run_summary(batches: list[dict], latest_invocation: dict) -> None:
    dry_runs = sum(1 for batch in batches if batch.get("dry_run"))
    total_events = sum(int(batch.get("event_count") or 0) for batch in batches)
    print("Runs")
    print(f"  batches          {len(batches)}")
    print(f"  batched events   {total_events}")
    print(f"  dry runs         {dry_runs}")
    print(f"  latest status    {short(latest_invocation.get('status'))}")
    print(f"  latest runner    {short(latest_invocation.get('runner'))}")
    print(f"  latest notify    {short(latest_invocation.get('notification_status'))}")
    if batches:
        print("  recent")
        for batch in batches[-4:]:
            print(
                f"    {short(batch.get('ts'))[:19]} "
                f"runner={short(batch.get('runner')):<6} "
                f"events={short(batch.get('event_count')):<3} "
                f"dry={bool(batch.get('dry_run'))}"
            )


def render_dashboard() -> None:
    state = read_json(DEFAULT_FEEDBACK / "reflector-state.json", {})
    scan = read_json(DEFAULT_FEEDBACK / "codex-transcript-scan-state.json", {})
    settings = read_json(SETTINGS, {})
    events = load_events()
    batches = read_jsonl(DEFAULT_FEEDBACK / "reflector-batches.jsonl")
    queue = read_jsonl(DEFAULT_FEEDBACK / "trigger-queue.jsonl")
    signal = load_signal_summary(events)
    queued = len(queue)
    lock = (DEFAULT_FEEDBACK / "reflector.lock").exists()
    latest_invocation = state.get("last_invocation") if isinstance(state, dict) else None
    if not isinstance(latest_invocation, dict):
        latest_invocation = {}
    else:
        latest_invocation = normalized_invocation(latest_invocation)
    width = terminal_width()
    chart_width = max(18, min(36, width - 84))
    diff_path, diff_lines = latest_diff_summary()

    print("Introspect")
    print("=" * min(width, 100))
    print(f"home        {DEFAULT_HOME}")
    print(f"runtime     {REPO}")
    print(
        "config      "
        f"mode={short(settings.get('reflect_mode'), 'immediate')} "
        f"runner={short(settings.get('reflector_runner'), 'default')} "
        f"sensitivity={short(settings.get('wake_sensitivity'), 'balanced')} "
        f"threshold={short(settings.get('wake_custom_threshold'), 'model')}"
    )
    print("links       " + " ".join(f"{label}={'ok' if ok else 'bad'}" for label, _path, ok in prompt_links()))
    print()
    print("Signal")
    total = max(signal["total"], 1)
    print(bar("logged", signal["total"], total, chart_width, suffix=str(signal["total"])))
    print(bar("woke", signal["woke"], total, chart_width))
    print(bar("review-only", signal["review"], total, chart_width))
    print(bar("backfilled", signal["backfilled"], total, chart_width))
    print(bar("assistant", signal["assistant"], total, chart_width))
    print()
    render_event_trend(events, width=chart_width)
    print()
    print("Runtime")
    print(f"  queued events     {queued}")
    print(f"  worker lock       {'present' if lock else 'clear'}")
    print(f"  scheduled retry   {short(state.get('scheduled_retry_at') if isinstance(state, dict) else None)}")
    print(f"  last scan         {short(scan.get('last_scan_at'))}")
    print(f"  last backfill     {short(scan.get('last_backfill_at'))}")
    print(f"  latest invocation {short(latest_invocation.get('status'))} via {short(latest_invocation.get('runner'))}")
    print(f"  notification      {short(latest_invocation.get('notification_status'))}")
    print()
    render_score_distribution(events, width=chart_width)
    print()
    render_run_summary(batches, latest_invocation)
    print()
    render_queue(queue, width)
    print()
    print("Latest Diff")
    for line in diff_lines or [f"{diff_path}"]:
        print(f"  {line}")
    print()
    print("Next")
    print("  introspect install --reflect-mode immediate")
    print("  introspect status")
    print("  introspect runs")
    print("  introspect diff")
    print("  introspect config --sensitivity sensitive --runner codex")


def dashboard(args: argparse.Namespace) -> int:
    while True:
        if args.watch:
            print("\033[2J\033[H", end="")
        render_dashboard()
        if not args.watch:
            return 0
        print()
        print("Refreshing. Press Ctrl-C to quit.")
        try:
            time.sleep(args.interval)
        except KeyboardInterrupt:
            print()
            return 0


def runs(args: argparse.Namespace) -> int:
    batches = read_jsonl(DEFAULT_FEEDBACK / "reflector-batches.jsonl")
    state = read_json(DEFAULT_FEEDBACK / "reflector-state.json", {})
    latest_invocation = state.get("last_invocation") if isinstance(state, dict) else None
    if isinstance(latest_invocation, dict):
        latest_invocation = normalized_invocation(latest_invocation)
        print("latest invocation:")
        print(f"  status   {short(latest_invocation.get('status'))}")
        print(f"  runner   {short(latest_invocation.get('runner'))}")
        print(f"  events   {short(latest_invocation.get('event_count'))}")
        print(f"  notify   {short(latest_invocation.get('notification_status'))}")
        print(f"  prompt   {short(latest_invocation.get('prompt_path'))}")
        print(f"  diff     {short(latest_invocation.get('surface_diff_path'))}")
        print()
    if not batches:
        print("No reflector runs recorded yet.")
        return 0
    print(f"recent runs ({min(args.limit, len(batches))} of {len(batches)}):")
    for batch in batches[-args.limit :]:
        print(
            f"  {short(batch.get('ts'))} "
            f"runner={short(batch.get('runner'))} "
            f"events={short(batch.get('event_count'))} "
            f"dry_run={bool(batch.get('dry_run'))}"
        )
        if batch.get("surface_diff_path"):
            print(f"    diff: {batch.get('surface_diff_path')}")
    return 0


def diff(args: argparse.Namespace) -> int:
    path = Path(args.path).expanduser() if args.path else latest_file(DEFAULT_FEEDBACK / "surface-diffs", "*.json")
    if path is None or not path.exists():
        print("No surface diff recorded yet.")
        return 0
    payload = read_json(path, {})
    print(f"diff: {path}")
    print(f"changed: {payload.get('changed_count', 0)}")
    for change in payload.get("changes", []):
        if not isinstance(change, dict):
            continue
        print()
        print(f"--- {short(change.get('change_type'))}: {short(change.get('display_path'))}")
        text = str(change.get("diff") or "")
        if args.summary:
            for line in text.splitlines()[:12]:
                print(line)
            if len(text.splitlines()) > 12:
                print("...")
        else:
            print(text)
    return 0


def config(args: argparse.Namespace) -> int:
    updates = {
        "--reflect-mode": args.mode,
        "--runner": args.runner,
        "--wake-sensitivity": args.sensitivity,
        "--wake-threshold": args.threshold,
        "--nightly-hour": args.nightly_hour,
        "--nightly-minute": args.nightly_minute,
        "--claude-model": args.claude_model,
        "--claude-fallback-model": args.claude_fallback_model,
        "--codex-model": args.codex_model,
    }
    install_args: list[str] = []
    for flag, value in updates.items():
        if value is not None:
            install_args.extend([flag, str(value)])
    if install_args:
        install_args.append("--no-backfill")
        return run([str(REPO / "scripts" / "install-hooks.sh"), *install_args])
    settings = read_json(SETTINGS, {})
    print(json.dumps(settings, indent=2, sort_keys=True))
    return 0


def notify(args: argparse.Namespace) -> int:
    script = (
        'on run argv\n'
        '  display notification (item 2 of argv) with title (item 1 of argv)\n'
        'end run\n'
    )
    result = subprocess.run(["osascript", "-e", script, args.title, args.message], check=False)
    return result.returncode


def main(argv: list[str] | None = None) -> int:
    raw_argv = list(sys.argv[1:] if argv is None else argv)
    if raw_argv and raw_argv[0] == "install":
        return install(argparse.Namespace(install_args=raw_argv[1:]))

    parser = argparse.ArgumentParser(prog="introspect")
    parser.add_argument("--version", action="store_true", help="print the runtime commit")
    sub = parser.add_subparsers(dest="command")

    install_parser = sub.add_parser("install", help="install prompt links, hooks, scanner, and backfill")
    install_parser.add_argument("install_args", nargs=argparse.REMAINDER)
    install_parser.set_defaults(func=install)

    uninstall_parser = sub.add_parser("uninstall", help="remove hooks, scanner, monitor, and prompt links")
    uninstall_parser.set_defaults(func=uninstall)

    status_parser = sub.add_parser("status", help="print setup and runtime status")
    status_parser.set_defaults(func=status)

    doctor_parser = sub.add_parser("doctor", help="status plus local tool/runtime checks")
    doctor_parser.set_defaults(func=doctor)

    dash_parser = sub.add_parser("dashboard", help="show the terminal dashboard")
    dash_parser.add_argument("--watch", action="store_true", help="refresh until Ctrl-C")
    dash_parser.add_argument("--interval", type=float, default=3.0)
    dash_parser.set_defaults(func=dashboard)

    onboard_parser = sub.add_parser("onboard", help="guided first-time setup")
    onboard_parser.add_argument("--yes", action="store_true", help="skip the confirmation prompt")
    onboard_parser.add_argument("--force", action="store_true", help="run setup even if already configured")
    onboard_parser.set_defaults(func=onboard)

    runs_parser = sub.add_parser("runs", help="show recent reflector runs")
    runs_parser.add_argument("-n", "--limit", type=int, default=12)
    runs_parser.set_defaults(func=runs)

    diff_parser = sub.add_parser("diff", help="show the latest agent-surface diff")
    diff_parser.add_argument("path", nargs="?")
    diff_parser.add_argument("--summary", action="store_true")
    diff_parser.set_defaults(func=diff)

    config_parser = sub.add_parser("config", help="print or apply runtime config")
    config_parser.add_argument("--mode", choices=["immediate", "nightly", "off"])
    config_parser.add_argument("--runner", choices=["default", "claude", "codex"])
    config_parser.add_argument("--sensitivity", choices=["quiet", "balanced", "sensitive", "custom"])
    config_parser.add_argument("--threshold")
    config_parser.add_argument("--nightly-hour")
    config_parser.add_argument("--nightly-minute")
    config_parser.add_argument("--claude-model")
    config_parser.add_argument("--claude-fallback-model")
    config_parser.add_argument("--codex-model")
    config_parser.set_defaults(func=config)

    run_parser = sub.add_parser("run", help="run Introspect on recent transcript changes")
    run_parser.add_argument("--host", choices=["codex", "claude", "opencode", "cursor", "unknown"], default="unknown")
    run_parser.add_argument("--event", choices=["stop", "manual"], default="manual")
    run_parser.add_argument("--cwd", default=os.getcwd())
    run_parser.add_argument("--transcript-path", action="append", default=[])
    run_parser.add_argument("--session-id", default="")
    run_parser.add_argument("--generation-id", default="")
    run_parser.add_argument("--apply", choices=["auto", "proposal", "never"], default="proposal")
    run_parser.add_argument("--min-turns", type=int, default=10)
    run_parser.add_argument("--min-minutes", type=float, default=120.0)
    run_parser.add_argument("--force", action="store_true")
    run_parser.add_argument("--json", action="store_true")
    run_parser.set_defaults(func=run_introspect)

    notify_parser = sub.add_parser("notify", help="send a best-effort macOS notification")
    notify_parser.add_argument("title")
    notify_parser.add_argument("message")
    notify_parser.set_defaults(func=notify)

    args = parser.parse_args(argv)
    if args.version:
        subprocess.call(["git", "-C", str(REPO), "rev-parse", "--short", "HEAD"])
        return 0
    if not hasattr(args, "func"):
        if not is_configured():
            return onboard(argparse.Namespace(yes=False, force=False))
        args.watch = False
        args.interval = 3.0
        return dashboard(args)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
